{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://echo.example/schemas/echo-pack.v1.json",
  "title": "ECHO Standalone Pack",
  "type": "object",
  "required": ["schemaVersion", "id", "name", "version", "engineVersion", "modules"],
  "properties": {
    "schemaVersion": {"type": "string"},
    "id": {"type": "string", "pattern": "^[a-z0-9_.-]+$"},
    "pack": {"type": "string", "pattern": "^[a-z0-9_.-]+$"},
    "name": {"type": "string", "minLength": 1},
    "version": {"type": "string", "minLength": 1},
    "engineVersion": {"type": "string", "minLength": 1},
    "runtimeTarget": {"type": "string"},
    "loader": {"type": "string"},
    "strictArtifacts": {"type": "boolean"},
    "strictContentGraph": {"type": "boolean"},
    "requireCrossRuntimeParity": {"type": "boolean"},
    "modules": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "pattern": "^[a-z0-9_.-]+$"}
    },
    "files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "path", "sha256", "size", "required", "trust"],
        "properties": {
          "id": {"type": "string"},
          "moduleId": {"type": "string"},
          "artifactName": {"type": "string"},
          "assetName": {"type": "string"},
          "path": {"type": "string", "minLength": 1},
          "artifactFamily": {"type": "string"},
          "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
          "size": {"type": "integer", "minimum": 0},
          "required": {"type": "boolean"},
          "side": {"type": "string"},
          "trust": {"enum": ["official", "developer", "data-only"]}
        }
      }
    },
    "moduleRequirements": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "version"],
        "properties": {
          "id": {"type": "string"},
          "moduleId": {"type": "string"},
          "version": {"type": "string"},
          "artifactFamily": {"type": "string"},
          "artifactName": {"type": "string"},
          "assetName": {"type": "string"},
          "path": {"type": "string"},
          "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
          "size": {"type": "integer", "minimum": 0},
          "required": {"type": "boolean"},
          "side": {"type": "string"},
          "trust": {"enum": ["official", "developer", "data-only"]}
        }
      }
    },
    "launch": {
      "type": "object",
      "properties": {
        "mainClass": {"type": "string"},
        "jvmArgs": {"type": "array", "items": {"type": "string"}},
        "gameArgs": {"type": "array", "items": {"type": "string"}}
      }
    },
    "runtime": {
      "type": "object",
      "properties": {
        "id": {"type": "string"},
        "target": {"type": "string"},
        "version": {"type": "string"},
        "requiredJava": {"type": "string"}
      }
    }
  },
  "additionalProperties": true
}
