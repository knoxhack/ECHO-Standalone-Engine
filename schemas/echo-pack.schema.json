{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://echo.example/schemas/echo-pack.v1.json",
  "title": "ECHO Standalone Pack",
  "type": "object",
  "required": ["schemaVersion", "id", "name", "version", "engineVersion", "modules"],
  "properties": {
    "schemaVersion": {"const": 1},
    "id": {"type": "string", "pattern": "^[a-z0-9_.-]+$"},
    "name": {"type": "string", "minLength": 1},
    "version": {"type": "string", "minLength": 1},
    "engineVersion": {"type": "string", "minLength": 1},
    "modules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "version", "file", "sha256", "required", "trust"],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z0-9_.-]+$"},
          "version": {"type": "string"},
          "file": {"type": "string", "minLength": 1},
          "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
          "required": {"type": "boolean"},
          "trust": {"enum": ["official", "developer", "data-only"]}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
